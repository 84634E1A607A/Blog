transition-duration()
  transition-duration: arguments
transition()
  transition: arguments
transform()
  transform: arguments
transition-delay()
  transition-delay: arguments
user-select()
  user-select: arguments

flex-wrapper($direction)
  display: flex
  flex-flow: $direction nowrap
  align-items: center
  { block }

transition-sign($sign = all)
  transition: $sign 280ms cubic-bezier(.8, 0, .2, 1)


headerStyle()
  +theme_light()
    background-color: mix($theme-color-main, #fff, 15%)
  +theme_dark()
    background-color: mix($theme-color-main-dark, #101010, 20%)
