{% extends "_layout.njk" %}
  {% block title %}
    {{config.title}}
  {% endblock %}

  {% block main %}
    {% if page.type == 'about' %}
      <div class="about syuanpi fadeInRightShort">
        <h2 class="title"> {{ __('nav.about') }} </h2>
        <div class="content">
          {{ page.content }}
        </div>
      </div>
      {% include "_partial/_post/comments.njk" %}
    {% else %}
      {{ page.content }}
    {% endif %}
  {% endblock %}
