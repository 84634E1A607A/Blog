{
  "name": "hexo-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "clean": "hexo clean",
    "dev": "concurrently -k -n HEXO,BS \"pnpm run dev:build\" \"pnpm run dev:serve\"",
    "dev:build": "hexo generate --watch --config _config.yml,_config.dev.yml",
    "dev:serve": "browser-sync start --server public --files \"public/**/*\" --port 4000 --host 127.0.0.1 --no-open --no-notify",
    "deploy": "hexo deploy"
  },
  "hexo": {
    "version": "8.1.2"
  },
  "dependencies": {
    "@foliojs-fork/linebreak": "^1.1.2",
    "@resvg/resvg-js": "^2.6.2",
    "fontkit": "^2.0.4",
    "hexo": "^8.1.2",
    "hexo-asset-link": "^2.3.1",
    "hexo-clean-css": "^2.0.0",
    "hexo-filter-mermaid": "file:filter/hexo-filter-mermaid",
    "hexo-fold": "^1.0.5",
    "hexo-generator-feed": "3.0.0",
    "hexo-generator-index": "^4.0.0",
    "hexo-generator-search": "^2.4.3",
    "hexo-generator-sitemap": "^3.0.1",
    "hexo-generator-tag": "^2.0.0",
    "hexo-highlighter-shiki": "^1.2.3",
    "hexo-renderer-markdown-it": "^7.1.1",
    "hexo-renderer-stylus": "^3.0.1",
    "hexo-server": "^3.0.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@master-hash/tree-sitter-highlight": "^1.2.2",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "hexo-neat": "^1.0.9"
  }
}